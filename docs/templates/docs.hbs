<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Ableton Composer</title>
    <meta name="description" content="{{description}}">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-white dark:bg-black">
    {{> header}}

    <div class="docs-container flex">
        <div id="mobile-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden md:hidden"></div>

        <aside id="sidebar" class="sidebar w-64 bg-white dark:bg-black min-h-screen border-r border-gray-300 dark:border-gray-700 fixed left-0 top-14 overflow-y-auto md:block hidden z-50">
            {{> sidebar}}
        </aside>

        <aside id="mobile-sidebar" class="mobile-sidebar w-64 bg-white dark:bg-black min-h-screen border-l border-gray-300 dark:border-gray-700 fixed right-0 top-14 overflow-y-auto transform translate-x-full transition-transform duration-300 z-50 md:hidden">
            {{> sidebar}}
        </aside>

        <main class="main-content flex-1 min-w-0 md:ml-64 xl:mr-64 p-4 sm:p-8 lg:p-12">
            <article class="max-w-3xl mx-auto prose">
                {{{content}}}
            </article>

            <div class="mt-16 pt-6 border-t border-gray-300 dark:border-gray-700 max-w-3xl mx-auto">
                <a href="https://github.com/delaudio/ableton-composer" class="text-xs text-gray-500 dark:text-gray-500 hover:text-black dark:hover:text-white">
                    Edit this page
                </a>
            </div>
        </main>

        <aside class="toc-sidebar w-64 fixed right-0 top-14 h-screen overflow-y-auto border-l border-gray-300 dark:border-gray-700 bg-white dark:bg-black hidden xl:block">
            <nav class="p-6">
                <h3 class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-500 mb-3">On this page</h3>
                <div id="toc-content" class="toc-links space-y-2 text-sm"></div>
            </nav>
        </aside>
    </div>

    <script src="/app.js"></script>
</body>
</html>
