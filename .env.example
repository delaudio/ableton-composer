# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use for generation (default: claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-5

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
# Default model for --provider openai
OPENAI_MODEL=gpt-5.2
# Request timeout for OpenAI provider in milliseconds
OPENAI_TIMEOUT_MS=120000
# Max automatic retries for OpenAI requests
OPENAI_MAX_RETRIES=0
# Default model for --provider codex
CODEX_MODEL=gpt-5-codex

# Weather (Open-Meteo — no API key required, just set your coordinates)
WEATHER_LAT=your_latitude
WEATHER_LON=your_longitude
WEATHER_CITY=your_city
